<Window x:Class="N01D.Cron.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N01D :: CRON" Height="720" Width="1050"
        Style="{StaticResource N01DWindow}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DPrimaryBrush}" BorderThickness="0,0,0,2">
            <Grid Margin="16,0">
                <TextBlock Text="[ N01D :: CRON ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource N01DPrimaryBrush}" 
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="+ NEW JOB" Style="{StaticResource N01DButton}" 
                            Click="BtnNewJob_Click" Margin="0,0,8,0"/>
                    <Button x:Name="btnStartAll" Content="▶ START ALL" Style="{StaticResource N01DButton}" 
                            Click="BtnStartAll_Click" Margin="0,0,8,0"/>
                    <Button Content="⏹ STOP ALL" Style="{StaticResource N01DButton}" 
                            Click="BtnStopAll_Click"
                            Foreground="{StaticResource N01DAccentBrush}" 
                            BorderBrush="{StaticResource N01DAccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Jobs DataGrid -->
        <Border Grid.Row="1" Background="{StaticResource N01DBackgroundAltBrush}" 
                CornerRadius="5" BorderBrush="{StaticResource N01DBorderBrush}" 
                BorderThickness="1" Margin="8,8,8,4">
            <DataGrid x:Name="dgJobs" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" Foreground="{StaticResource N01DTextBrush}"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource N01DBorderBrush}"
                      FontFamily="{StaticResource N01DMonoFont}" FontSize="12"
                      RowBackground="#0D0D0D" AlternatingRowBackground="#141414"
                      SelectionChanged="DgJobs_SelectionChanged"
                      HeadersVisibility="Column">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1A1A1A"/>
                        <Setter Property="Foreground" Value="#0ABDC6"/>
                        <Setter Property="FontFamily" Value="Consolas"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding StatusIcon}" Width="70"/>
                    <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="180"/>
                    <DataGridTextColumn Header="SCHEDULE" Binding="{Binding Schedule}" Width="140"/>
                    <DataGridTextColumn Header="COMMAND" Binding="{Binding Command}" Width="*"/>
                    <DataGridTextColumn Header="LAST RUN" Binding="{Binding LastRunDisplay}" Width="140"/>
                    <DataGridTextColumn Header="NEXT RUN" Binding="{Binding NextRunDisplay}" Width="140"/>
                    <DataGridTextColumn Header="RUNS" Binding="{Binding RunCount}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Log Output -->
        <Border Grid.Row="2" Background="{StaticResource N01DBackgroundAltBrush}" 
                CornerRadius="5" BorderBrush="{StaticResource N01DBorderBrush}" 
                BorderThickness="1" Margin="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="8,6,8,0">
                    <TextBlock Text="LOG OUTPUT" FontFamily="{StaticResource N01DMonoFont}" FontSize="11" 
                               FontWeight="Bold" Foreground="{StaticResource N01DSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="▶ RUN NOW" Style="{StaticResource N01DButton}" FontSize="10" 
                                Click="BtnRunNow_Click" Margin="0,0,4,0" Padding="8,3"/>
                        <Button Content="🗑 DELETE" Style="{StaticResource N01DButton}" FontSize="10" 
                                Click="BtnDeleteJob_Click" Padding="8,3"
                                Foreground="{StaticResource N01DAccentBrush}" 
                                BorderBrush="{StaticResource N01DAccentBrush}"/>
                    </StackPanel>
                </Grid>
                <TextBox x:Name="txtLog" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                         Margin="8,4,8,8" IsReadOnly="True" AcceptsReturn="True" 
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="lblStatus" Text="[ IDLE ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DPrimaryBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="N01D Cron v1.0.0 | bad-antics" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
