<Window x:Class="N01D.Wipe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N01D :: WIPE" Height="650" Width="800"
        Style="{StaticResource N01DWindow}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DAccentBrush}" BorderThickness="0,0,0,2">
            <Grid Margin="16,0">
                <TextBlock Text="[ N01D :: WIPE ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource N01DAccentBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="⚠ PERMANENT DELETION" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DWarningBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Config / Drop -->
        <Border Grid.Row="1" Background="{StaticResource N01DBackgroundAltBrush}" 
                CornerRadius="5" BorderBrush="{StaticResource N01DBorderBrush}" 
                BorderThickness="1" Margin="8,8,8,4">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="WIPE METHOD:" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmbMethod" SelectedIndex="1" Width="280"
                              Background="#1A1A1A" Foreground="#E0E0E0" FontFamily="Consolas">
                        <ComboBoxItem Content="1-Pass Zero Fill (Fast)"/>
                        <ComboBoxItem Content="3-Pass DoD 5220.22-M"/>
                        <ComboBoxItem Content="7-Pass DoD 5220.22-M Extended"/>
                        <ComboBoxItem Content="35-Pass Gutmann (Paranoid)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="chkVerify" IsChecked="True" Foreground="#E0E0E0" 
                              FontFamily="Consolas" Content="Verify after wipe" Margin="0,0,16,0"/>
                    <CheckBox x:Name="chkRename" IsChecked="True" Foreground="#E0E0E0" 
                              FontFamily="Consolas" Content="Rename before delete"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="📁 ADD FILES" Style="{StaticResource N01DButton}" 
                            Click="BtnAddFiles_Click" Margin="0,0,8,0"/>
                    <Button Content="📂 ADD FOLDER" Style="{StaticResource N01DButton}" 
                            Click="BtnAddFolder_Click" Margin="0,0,8,0"/>
                    <Button Content="🗑 REMOVE SELECTED" Style="{StaticResource N01DButton}" 
                            Click="BtnRemove_Click" FontSize="11"/>
                </StackPanel>

                <Border Grid.Column="1" Grid.RowSpan="3" Background="#141414" CornerRadius="5" 
                        BorderBrush="#333333" BorderThickness="2"
                        Width="180" Margin="12,0,0,0">
                    <TextBlock Text="📥&#10;&#10;DROP FILES&#10;HERE" FontFamily="Consolas" FontSize="13" 
                               Foreground="#808080" TextAlignment="Center" 
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- File List -->
        <ListBox x:Name="lstFiles" Grid.Row="2" Style="{StaticResource N01DListBox}" 
                 Margin="8,4" SelectionMode="Extended">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" 
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Path}" Foreground="#E0E0E0" 
                                   FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" 
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding SizeLabel}" Foreground="#808080" 
                                   FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Progress & Wipe Button -->
        <Grid Grid.Row="3" Margin="8,4,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar x:Name="pgWipe" Grid.Row="0" Style="{StaticResource N01DProgressBar}" 
                         Margin="0,0,0,8" Visibility="Collapsed"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblProgress" Grid.Column="0" Text="" 
                           FontFamily="{StaticResource N01DMonoFont}" FontSize="11" 
                           Foreground="{StaticResource N01DTextDimBrush}" VerticalAlignment="Center"/>
                <Button x:Name="btnWipe" Grid.Column="1" Content="💀 WIPE ALL" 
                        Style="{StaticResource N01DButton}" Click="BtnWipe_Click" FontSize="14" 
                        Padding="24,8" Foreground="{StaticResource N01DAccentBrush}" 
                        BorderBrush="{StaticResource N01DAccentBrush}"/>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="lblStatus" Text="[ READY ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DPrimaryBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="N01D Wipe v1.0.0 | bad-antics" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
