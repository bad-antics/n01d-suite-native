<Window x:Class="N01D.Pulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N01D :: PULSE" Height="720" Width="1100"
        Style="{StaticResource N01DWindow}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DSecondaryBrush}" BorderThickness="0,0,0,2">
            <Grid Margin="16,0">
                <TextBlock Text="[ N01D :: PULSE ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource N01DSecondaryBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="lblLocalIP" Text="" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Main: Tabs -->
        <TabControl Grid.Row="1" Style="{StaticResource N01DTabControl}" Margin="8">
            <!-- Ping Tab -->
            <TabItem Header="📡 PING" Style="{StaticResource N01DTabItem}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <TextBox x:Name="txtPingHost" Style="{StaticResource N01DTextBox}" 
                                 Width="300" Text="8.8.8.8"/>
                        <Button Content="PING" Style="{StaticResource N01DButton}" 
                                Click="BtnPing_Click" Margin="8,0,0,0"/>
                        <Button x:Name="btnPingSweep" Content="SWEEP /24" Style="{StaticResource N01DButton}" 
                                Click="BtnPingSweep_Click" Margin="8,0,0,0"/>
                        <Button x:Name="btnStopPing" Content="⏹ STOP" Style="{StaticResource N01DButton}" 
                                Click="BtnStop_Click" Margin="8,0,0,0" IsEnabled="False"
                                Foreground="{StaticResource N01DAccentBrush}" 
                                BorderBrush="{StaticResource N01DAccentBrush}"/>
                    </StackPanel>
                    <TextBox x:Name="txtPingOutput" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- Port Scan Tab -->
            <TabItem Header="🔍 PORT SCAN" Style="{StaticResource N01DTabItem}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="HOST:" FontFamily="{StaticResource N01DMonoFont}" 
                                   Foreground="{StaticResource N01DTextDimBrush}" 
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="txtScanHost" Style="{StaticResource N01DTextBox}" 
                                 Width="200" Text="127.0.0.1"/>
                        <TextBlock Text="  PORTS:" FontFamily="{StaticResource N01DMonoFont}" 
                                   Foreground="{StaticResource N01DTextDimBrush}" 
                                   VerticalAlignment="Center" Margin="8,0,8,0"/>
                        <TextBox x:Name="txtPorts" Style="{StaticResource N01DTextBox}" 
                                 Width="200" Text="1-1024"/>
                        <Button Content="SCAN" Style="{StaticResource N01DButton}" 
                                Click="BtnScan_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ProgressBar x:Name="pgScan" Grid.Row="1" Style="{StaticResource N01DProgressBar}" 
                                 Margin="0,0,0,8" Visibility="Collapsed"/>
                    <TextBox x:Name="txtScanOutput" Grid.Row="2" Style="{StaticResource N01DTextBox}" 
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- Traceroute Tab -->
            <TabItem Header="🛤 TRACEROUTE" Style="{StaticResource N01DTabItem}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <TextBox x:Name="txtTraceHost" Style="{StaticResource N01DTextBox}" 
                                 Width="300" Text="google.com"/>
                        <Button Content="TRACE" Style="{StaticResource N01DButton}" 
                                Click="BtnTrace_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="txtTraceOutput" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- DNS / WHOIS Tab -->
            <TabItem Header="🌐 DNS / WHOIS" Style="{StaticResource N01DTabItem}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <TextBox x:Name="txtDnsHost" Style="{StaticResource N01DTextBox}" 
                                 Width="300" Text="example.com"/>
                        <Button Content="DNS LOOKUP" Style="{StaticResource N01DButton}" 
                                Click="BtnDns_Click" Margin="8,0,0,0"/>
                        <Button Content="WHOIS" Style="{StaticResource N01DButton}" 
                                Click="BtnWhois_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="txtDnsOutput" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" FontSize="12"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="lblStatus" Text="[ READY ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DPrimaryBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="N01D Pulse v1.0.0 | bad-antics" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
