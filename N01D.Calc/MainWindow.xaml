<Window x:Class="N01D.Calc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N01D :: CALC" Height="700" Width="900"
        Style="{StaticResource N01DWindow}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DPrimaryBrush}" BorderThickness="0,0,0,2">
            <TextBlock Text="[ N01D :: CALC ]" FontFamily="{StaticResource N01DMonoFont}" 
                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource N01DPrimaryBrush}" 
                       VerticalAlignment="Center" Margin="16,0"/>
        </Border>

        <!-- Main: Tabs -->
        <TabControl Grid.Row="1" Style="{StaticResource N01DTabControl}" Margin="8">

            <!-- Number Converter Tab -->
            <TabItem Header="🔢 CONVERTER" Style="{StaticResource N01DTabItem}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="DECIMAL:" FontFamily="{StaticResource N01DMonoFont}" 
                               Foreground="{StaticResource N01DPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtDec" Grid.Row="0" Grid.Column="1" Style="{StaticResource N01DTextBox}" 
                             FontSize="16" Margin="0,0,0,8" TextChanged="TxtDec_TextChanged"/>

                    <TextBlock Grid.Row="1" Text="HEX:" FontFamily="{StaticResource N01DMonoFont}" 
                               Foreground="{StaticResource N01DSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtHex" Grid.Row="1" Grid.Column="1" Style="{StaticResource N01DTextBox}" 
                             FontSize="16" Margin="0,0,0,8" TextChanged="TxtHex_TextChanged"/>

                    <TextBlock Grid.Row="2" Text="OCTAL:" FontFamily="{StaticResource N01DMonoFont}" 
                               Foreground="{StaticResource N01DWarningBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtOct" Grid.Row="2" Grid.Column="1" Style="{StaticResource N01DTextBox}" 
                             FontSize="16" Margin="0,0,0,8" TextChanged="TxtOct_TextChanged"/>

                    <TextBlock Grid.Row="3" Text="BINARY:" FontFamily="{StaticResource N01DMonoFont}" 
                               Foreground="{StaticResource N01DAccentBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtBin" Grid.Row="3" Grid.Column="1" Style="{StaticResource N01DTextBox}" 
                             FontSize="16" Margin="0,0,0,8" TextChanged="TxtBin_TextChanged"/>

                    <TextBlock Grid.Row="4" Text="ASCII:" FontFamily="{StaticResource N01DMonoFont}" 
                               Foreground="{StaticResource N01DTextDimBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtAscii" Grid.Row="4" Grid.Column="1" Style="{StaticResource N01DTextBox}" 
                             FontSize="16" Margin="0,0,0,8" IsReadOnly="True"/>

                    <!-- Bitwise Ops -->
                    <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Text="BITWISE OPERATIONS" 
                               FontFamily="{StaticResource N01DMonoFont}" FontSize="12" FontWeight="Bold" 
                               Foreground="{StaticResource N01DSecondaryBrush}" Margin="0,12,0,8"/>

                    <WrapPanel Grid.Row="6" Grid.ColumnSpan="2">
                        <Button Content="NOT" Style="{StaticResource N01DButton}" Click="BtnNot_Click" Margin="0,0,4,4"/>
                        <Button Content="SHL" Style="{StaticResource N01DButton}" Click="BtnShl_Click" Margin="0,0,4,4"/>
                        <Button Content="SHR" Style="{StaticResource N01DButton}" Click="BtnShr_Click" Margin="0,0,4,4"/>
                        <Button Content="SWAP ENDIAN" Style="{StaticResource N01DButton}" Click="BtnSwapEndian_Click" Margin="0,0,4,4"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- Hash Generator Tab -->
            <TabItem Header="🔐 HASH" Style="{StaticResource N01DTabItem}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="INPUT TEXT:" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtHashInput" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <Button Grid.Row="2" Content="GENERATE HASHES" Style="{StaticResource N01DButton}" 
                            Click="BtnHash_Click" HorizontalAlignment="Left" Margin="0,8,0,8"/>

                    <TextBox x:Name="txtHashOutput" Grid.Row="3" Style="{StaticResource N01DTextBox}" 
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- Base64 / URL Encode Tab -->
            <TabItem Header="📦 ENCODE" Style="{StaticResource N01DTabItem}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="INPUT:" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtEncodeInput" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <WrapPanel Grid.Row="2" Margin="0,8">
                        <Button Content="BASE64 ENCODE" Style="{StaticResource N01DButton}" Click="BtnB64Enc_Click" Margin="0,0,4,0"/>
                        <Button Content="BASE64 DECODE" Style="{StaticResource N01DButton}" Click="BtnB64Dec_Click" Margin="0,0,4,0"/>
                        <Button Content="URL ENCODE" Style="{StaticResource N01DButton}" Click="BtnUrlEnc_Click" Margin="0,0,4,0"/>
                        <Button Content="URL DECODE" Style="{StaticResource N01DButton}" Click="BtnUrlDec_Click" Margin="0,0,4,0"/>
                        <Button Content="HEX ENCODE" Style="{StaticResource N01DButton}" Click="BtnHexEnc_Click" Margin="0,0,4,0"/>
                        <Button Content="HEX DECODE" Style="{StaticResource N01DButton}" Click="BtnHexDec_Click" Margin="0,0,4,0"/>
                    </WrapPanel>

                    <TextBox x:Name="txtEncodeOutput" Grid.Row="3" Style="{StaticResource N01DTextBox}" 
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </TabItem>

            <!-- Regex Tester Tab -->
            <TabItem Header="⚡ REGEX" Style="{StaticResource N01DTabItem}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PATTERN:" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtRegexPattern" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             FontSize="14" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Text="TEST STRING:" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtRegexInput" Grid.Row="3" Style="{StaticResource N01DTextBox}" 
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                             TextChanged="TxtRegex_TextChanged"/>

                    <TextBlock Grid.Row="4" Text="MATCHES:" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,8,0,4"/>
                    <TextBox x:Name="txtRegexOutput" Grid.Row="5" Style="{StaticResource N01DTextBox}" 
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" FontSize="12"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="lblStatus" Text="[ READY ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DPrimaryBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="N01D Calc v1.0.0 | bad-antics" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
