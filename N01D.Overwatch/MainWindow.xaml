<Window x:Class="N01D.Overwatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="N01D :: OVERWATCH" Width="1400" Height="900"
        Style="{StaticResource XChatWindow}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource XChatBackgroundBrush}" BorderBrush="{StaticResource XChatBlueBrush}" BorderThickness="0,0,0,2" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="18" FontWeight="Bold">
                    <Run Text="[ " Foreground="{StaticResource XChatTextDimBrush}"/>
                    <Run Text="N01D" Foreground="{StaticResource XChatBlueBrush}"/>
                    <Run Text=" :: " Foreground="{StaticResource XChatTextDimBrush}"/>
                    <Run Text="OVERWATCH" Foreground="{StaticResource XChatPurpleBrush}"/>
                    <Run Text=" ]" Foreground="{StaticResource XChatTextDimBrush}"/>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtThreatLevel" FontFamily="Consolas" FontSize="14" 
                               Foreground="{StaticResource XChatOrangeBrush}" VerticalAlignment="Center" Margin="20,0"
                               Text="THREAT LEVEL: ELEVATED"/>
                    <TextBlock x:Name="txtAlertCount" FontFamily="Consolas" FontSize="13"
                               Foreground="{StaticResource XChatRedBrush}" VerticalAlignment="Center"
                               Text="⚠ 0 ALERTS"/>
                    <TextBlock Text=" │ " FontFamily="Consolas" FontSize="12" Foreground="{StaticResource XChatBorderBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtLiveStatus" FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource XChatTextDimBrush}" VerticalAlignment="Center"
                               Text="○ OFFLINE"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="btnLiveTracking" Content="▶ GO LIVE" Style="{StaticResource XChatButton}"
                            Click="BtnToggleLiveTracking_Click" FontSize="11" Margin="4,0"/>
                    <Button x:Name="btnRefresh" Content="⟳ REFRESH" Style="{StaticResource XChatButton}"
                            Click="BtnRefresh_Click" FontSize="11" Margin="4,0"/>
                    <Button x:Name="btnExportJson" Content="📥 JSON" Style="{StaticResource XChatButton}"
                            Click="BtnExportJson_Click" FontSize="11" Margin="4,0"/>
                    <Button x:Name="btnExportCsv" Content="📥 CSV" Style="{StaticResource XChatButton}"
                            Click="BtnExportCsv_Click" FontSize="11" Margin="4,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{StaticResource XChatSurfaceBrush}" Padding="12,6" BorderBrush="{StaticResource XChatBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="txtSearch" Grid.Column="1" Style="{StaticResource XChatTextBox}"
                         FontSize="12" TextChanged="TxtSearch_TextChanged" 
                         Tag="Search events..."/>

                <TextBlock Grid.Column="2" Text="  FILTER:" FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource XChatTextDimBrush}" VerticalAlignment="Center" Margin="10,0,6,0"/>

                <CheckBox x:Name="chkMilitary" Grid.Column="3" Content="⚔ Military" Foreground="{StaticResource XChatTextBrush}"
                          FontFamily="Consolas" FontSize="11" IsChecked="True" VerticalAlignment="Center"
                          Margin="4,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="chkDiplomatic" Grid.Column="4" Content="🏛 Diplomatic" Foreground="{StaticResource XChatTextBrush}"
                          FontFamily="Consolas" FontSize="11" IsChecked="True" VerticalAlignment="Center"
                          Margin="4,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="chkEconomic" Grid.Column="5" Content="💰 Economic" Foreground="{StaticResource XChatTextBrush}"
                          FontFamily="Consolas" FontSize="11" IsChecked="True" VerticalAlignment="Center"
                          Margin="4,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="chkNuclear" Grid.Column="6" Content="☢ Nuclear" Foreground="{StaticResource XChatTextBrush}"
                          FontFamily="Consolas" FontSize="11" IsChecked="True" VerticalAlignment="Center"
                          Margin="4,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="chkCyber" Grid.Column="7" Content="💻 Cyber" Foreground="{StaticResource XChatTextBrush}"
                          FontFamily="Consolas" FontSize="11" IsChecked="True" VerticalAlignment="Center"
                          Margin="4,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="chkHumanitarian" Grid.Column="8" Content="🏥 Humanitarian" Foreground="{StaticResource XChatTextBrush}"
                          FontFamily="Consolas" FontSize="11" IsChecked="True" VerticalAlignment="Center"
                          Margin="4,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="chkIntelligence" Grid.Column="9" Content="🕵 Intel" Foreground="{StaticResource XChatTextBrush}"
                          FontFamily="Consolas" FontSize="11" IsChecked="True" VerticalAlignment="Center"
                          Margin="4,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>

                <StackPanel Grid.Column="11" Orientation="Horizontal">
                    <TextBlock Text="AUTO:" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource XChatTextDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="cmbInterval" Width="70" FontFamily="Consolas" FontSize="11"
                              Background="{StaticResource XChatInputBgBrush}" Foreground="{StaticResource XChatTextBrush}" BorderBrush="{StaticResource XChatBorderBrush}"
                              SelectionChanged="CmbInterval_Changed">
                        <ComboBoxItem Content="OFF" IsSelected="True"/>
                        <ComboBoxItem Content="1 min"/>
                        <ComboBoxItem Content="5 min"/>
                        <ComboBoxItem Content="15 min"/>
                        <ComboBoxItem Content="30 min"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content — Tab Control -->
        <TabControl x:Name="tabMain" Grid.Row="2" Style="{StaticResource XChatTabControl}" Margin="0">
            
            <!-- TIMELINE TAB -->
            <TabItem Header="📡 TIMELINE" Style="{StaticResource XChatTabItem}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="lstTimeline" Grid.Column="0" Style="{StaticResource XChatListBox}"
                             Background="{StaticResource XChatBackgroundBrush}" BorderThickness="0"
                             SelectionChanged="LstTimeline_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="2" CornerRadius="3"
                                        BorderThickness="0,0,3,0" BorderBrush="{Binding SeverityColor}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0">
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="14" 
                                                       Margin="0,0,6,0" VerticalAlignment="Center"
                                                       DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding SeverityLabel}" FontFamily="Consolas"
                                                       FontSize="10" Foreground="{Binding SeverityColor}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                                       DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding TimeAgo}" FontFamily="Consolas"
                                                       FontSize="10" Foreground="{StaticResource XChatTextDimBrush}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                                       DockPanel.Dock="Right"/>
                                            <TextBlock Text="{Binding Title}" FontFamily="Consolas"
                                                       FontSize="12" Foreground="{StaticResource XChatTextBrush}" FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>

                                        <TextBlock Grid.Row="1" Text="{Binding Summary}" FontFamily="Consolas"
                                                   FontSize="11" Foreground="{StaticResource XChatTextDimBrush}" TextWrapping="Wrap"
                                                   MaxHeight="40" Margin="20,3,0,0"/>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,4,0,0">
                                            <TextBlock Text="{Binding Source}" FontFamily="Consolas"
                                                       FontSize="10" Foreground="{StaticResource XChatCyanBrush}" Margin="0,0,12,0"/>
                                            <TextBlock Text="{Binding TagsDisplay}" FontFamily="Consolas"
                                                       FontSize="10" Foreground="{StaticResource XChatTextDimBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Detail Panel -->
                    <Border Grid.Column="1" Background="{StaticResource XChatSurfaceBrush}" BorderBrush="{StaticResource XChatBorderBrush}" BorderThickness="1,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="pnlDetail" Margin="12">
                                <TextBlock Text="EVENT DETAIL" FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource XChatPurpleBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock x:Name="txtDetailTitle" FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource XChatBlueBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtDetailSeverity" FontFamily="Consolas" FontSize="11"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="txtDetailCategory" FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource XChatTextBrush}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="txtDetailSource" FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource XChatCyanBrush}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="txtDetailTime" FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource XChatTextDimBrush}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="txtDetailLocation" FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource XChatOrangeBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtDetailSummary" FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource XChatTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtDetailTags" FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource XChatTextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Button x:Name="btnOpenUrl" Content="🔗 OPEN SOURCE" Style="{StaticResource XChatButton}"
                                        Click="BtnOpenUrl_Click" FontSize="11" HorizontalAlignment="Left"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- MAP TAB -->
            <TabItem Header="🗺 MAP" Style="{StaticResource XChatTabItem}">
                <wv2:WebView2 x:Name="webMap" DefaultBackgroundColor="#080810"/>
            </TabItem>

            <!-- FLIGHTS TAB -->
            <TabItem Header="✈ FLIGHTS" Style="{StaticResource XChatTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource XChatSurfaceBrush}" Padding="10,6">
                        <DockPanel>
                            <TextBlock Text="MILITARY AIRCRAFT — MIDDLE EAST AIRSPACE" FontFamily="Consolas"
                                       FontSize="12" Foreground="{StaticResource XChatBlueBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtFlightCount" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource XChatTextDimBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"
                                       DockPanel.Dock="Right"/>
                            <Button Content="⟳ SCAN" Style="{StaticResource XChatButton}"
                                    Click="BtnScanFlights_Click" FontSize="11" HorizontalAlignment="Right"
                                    DockPanel.Dock="Right" Margin="0,0,10,0"/>
                        </DockPanel>
                    </Border>
                    <DataGrid x:Name="dgFlights" Grid.Row="1" AutoGenerateColumns="False"
                              Background="{StaticResource XChatBackgroundBrush}" Foreground="{StaticResource XChatTextBrush}" 
                              FontFamily="Consolas" FontSize="11"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource XChatSurfaceBrush}" 
                              RowBackground="{StaticResource XChatBackgroundBrush}"
                              AlternatingRowBackground="{StaticResource XChatBackgroundAltBrush}" 
                              IsReadOnly="True" HeadersVisibility="Column" CanUserSortColumns="True">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource XChatSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource XChatBlueBrush}"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="{StaticResource XChatBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CALLSIGN" Binding="{Binding Callsign}" Width="120"/>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding AircraftType}" Width="160"/>
                            <DataGridTextColumn Header="COUNTRY" Binding="{Binding Country}" Width="140"/>
                            <DataGridTextColumn Header="ALT (m)" Binding="{Binding Altitude, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="SPD (kts)" Binding="{Binding Speed, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="HDG" Binding="{Binding Heading, StringFormat=N0}" Width="60"/>
                            <DataGridTextColumn Header="LAT" Binding="{Binding Latitude, StringFormat=F3}" Width="90"/>
                            <DataGridTextColumn Header="LON" Binding="{Binding Longitude, StringFormat=F3}" Width="90"/>
                            <DataGridTextColumn Header="ICAO24" Binding="{Binding Registration}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- MARITIME TAB -->
            <TabItem Header="🚢 MARITIME" Style="{StaticResource XChatTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource XChatSurfaceBrush}" Padding="10,6">
                        <DockPanel>
                            <TextBlock Text="MARITIME DOMAIN AWARENESS — CRITICAL CHOKEPOINTS" FontFamily="Consolas"
                                       FontSize="12" Foreground="{StaticResource XChatBlueBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="⟳ SCAN" Style="{StaticResource XChatButton}"
                                    Click="BtnScanShips_Click" FontSize="11" HorizontalAlignment="Right"
                                    DockPanel.Dock="Right"/>
                        </DockPanel>
                    </Border>
                    <DataGrid x:Name="dgVessels" Grid.Row="1" AutoGenerateColumns="False"
                              Background="{StaticResource XChatBackgroundBrush}" Foreground="{StaticResource XChatTextBrush}" 
                              FontFamily="Consolas" FontSize="11"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource XChatSurfaceBrush}" 
                              RowBackground="{StaticResource XChatBackgroundBrush}"
                              AlternatingRowBackground="{StaticResource XChatBackgroundAltBrush}" 
                              IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource XChatSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource XChatBlueBrush}"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="{StaticResource XChatBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding VesselType}" Width="160"/>
                            <DataGridTextColumn Header="FLAG" Binding="{Binding Flag}" Width="80"/>
                            <DataGridTextColumn Header="LAT" Binding="{Binding Latitude, StringFormat=F3}" Width="90"/>
                            <DataGridTextColumn Header="LON" Binding="{Binding Longitude, StringFormat=F3}" Width="90"/>
                            <DataGridTextColumn Header="SPEED" Binding="{Binding Speed, StringFormat=F1}" Width="70"/>
                            <DataGridTextColumn Header="DEST" Binding="{Binding Destination}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- WAR OPS TAB -->
            <TabItem Header="⚔ WAR OPS" Style="{StaticResource XChatTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource XChatSurfaceBrush}" Padding="10,6">
                        <DockPanel>
                            <TextBlock Text="WAR ACTIONS MONITOR — KINETIC &amp; NON-KINETIC OPS" FontFamily="Consolas"
                                       FontSize="12" Foreground="{StaticResource XChatRedBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="⟳ SCAN" Style="{StaticResource XChatButton}"
                                    Click="BtnScanWarOps_Click" FontSize="11" HorizontalAlignment="Right"
                                    DockPanel.Dock="Right" Margin="0,0,10,0"/>
                            <TextBlock x:Name="txtWarOpsCount" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource XChatTextDimBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"
                                       DockPanel.Dock="Right"/>
                        </DockPanel>
                    </Border>

                    <TabControl Grid.Row="1" Style="{StaticResource XChatTabControl}">
                        <!-- SIGACT Sub-Tab -->
                        <TabItem Header="🎯 SIGACT" Style="{StaticResource XChatTabItem}">
                            <ListBox x:Name="lstSigact" Style="{StaticResource XChatListBox}"
                                     Background="{StaticResource XChatBackgroundBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,6" Margin="2" CornerRadius="3"
                                                BorderThickness="0,0,3,0" BorderBrush="{Binding SeverityColor}">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding CategoryIcon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding SeverityLabel}" FontFamily="Consolas" FontSize="10"
                                                               Foreground="{Binding SeverityColor}" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding TimeAgo}" FontFamily="Consolas" FontSize="10"
                                                               Foreground="{StaticResource XChatTextDimBrush}" VerticalAlignment="Center"
                                                               HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                                    <TextBlock Text="{Binding Title}" FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource XChatTextBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Summary}" FontFamily="Consolas" FontSize="10"
                                                           Foreground="{StaticResource XChatTextDimBrush}" TextWrapping="Wrap"
                                                           MaxHeight="32" Margin="18,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <!-- Sanctions/Arms Sub-Tab -->
                        <TabItem Header="📜 SANCTIONS" Style="{StaticResource XChatTabItem}">
                            <ListBox x:Name="lstSanctions" Style="{StaticResource XChatListBox}"
                                     Background="{StaticResource XChatBackgroundBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,6" Margin="2" CornerRadius="3"
                                                BorderThickness="0,0,3,0" BorderBrush="{Binding SeverityColor}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontFamily="Consolas" FontSize="11"
                                                           Foreground="{StaticResource XChatTextBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Summary}" FontFamily="Consolas" FontSize="10"
                                                           Foreground="{StaticResource XChatTextDimBrush}" TextWrapping="Wrap"
                                                           MaxHeight="32" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Source}" FontFamily="Consolas" FontSize="9"
                                                           Foreground="{StaticResource XChatCyanBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <!-- Cyber Sub-Tab -->
                        <TabItem Header="💻 CYBER" Style="{StaticResource XChatTabItem}">
                            <ListBox x:Name="lstCyberOps" Style="{StaticResource XChatListBox}"
                                     Background="{StaticResource XChatBackgroundBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,6" Margin="2" CornerRadius="3"
                                                BorderThickness="0,0,3,0" BorderBrush="{Binding SeverityColor}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontFamily="Consolas" FontSize="11"
                                                           Foreground="{StaticResource XChatTextBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Summary}" FontFamily="Consolas" FontSize="10"
                                                           Foreground="{StaticResource XChatTextDimBrush}" TextWrapping="Wrap"
                                                           MaxHeight="32" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Source}" FontFamily="Consolas" FontSize="9"
                                                           Foreground="{StaticResource XChatCyanBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>

                        <!-- Proxy/Militia Sub-Tab -->
                        <TabItem Header="🏴 PROXY" Style="{StaticResource XChatTabItem}">
                            <ListBox x:Name="lstProxy" Style="{StaticResource XChatListBox}"
                                     Background="{StaticResource XChatBackgroundBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,6" Margin="2" CornerRadius="3"
                                                BorderThickness="0,0,3,0" BorderBrush="{Binding SeverityColor}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontFamily="Consolas" FontSize="11"
                                                           Foreground="{StaticResource XChatTextBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Summary}" FontFamily="Consolas" FontSize="10"
                                                           Foreground="{StaticResource XChatTextDimBrush}" TextWrapping="Wrap"
                                                           MaxHeight="32" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Source}" FontFamily="Consolas" FontSize="9"
                                                           Foreground="{StaticResource XChatCyanBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <!-- ALERTS TAB -->
            <TabItem Header="🔔 ALERTS" Style="{StaticResource XChatTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource XChatSurfaceBrush}" Padding="10,6">
                        <TextBlock Text="ACTIVE ALERT RULES" FontFamily="Consolas"
                                   FontSize="12" Foreground="{StaticResource XChatPurpleBrush}" FontWeight="Bold"/>
                    </Border>
                    <ListBox x:Name="lstAlerts" Grid.Row="1" Style="{StaticResource XChatListBox}"
                             Background="{StaticResource XChatBackgroundBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" Margin="2" CornerRadius="3"
                                        Background="{StaticResource XChatSurfaceBrush}" BorderBrush="{StaticResource XChatBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Name}" FontFamily="Consolas" FontSize="12"
                                                       Foreground="{StaticResource XChatBlueBrush}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding StatusText}" FontFamily="Consolas" FontSize="10"
                                                       Foreground="{Binding StatusColor}" HorizontalAlignment="Right"
                                                       DockPanel.Dock="Right"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Description}" FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource XChatTextDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- ECLIPSE TAB -->
            <TabItem Header="🌑 ECLIPSE" Style="{StaticResource XChatTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Eclipse Header with Countdown -->
                    <Border Grid.Row="0" Background="{StaticResource XChatSurfaceBrush}" Padding="10,8">
                        <DockPanel>
                            <TextBlock Text="ECLIPSE MONITORING — OPTICAL/ISR IMPACT ANALYSIS" FontFamily="Consolas"
                                       FontSize="12" Foreground="{StaticResource XChatBlueBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="⟳ REFRESH" Style="{StaticResource XChatButton}"
