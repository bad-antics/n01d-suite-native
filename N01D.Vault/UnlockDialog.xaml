<Window x:Class="N01D.Vault.UnlockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N01D :: VAULT — UNLOCK" Height="220" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0D0D0D">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔐 MASTER PASSWORD" FontFamily="Consolas" FontSize="16" 
                   FontWeight="Bold" Foreground="#FF0055" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="Enter your master password to unlock the vault:" 
                   FontFamily="Consolas" FontSize="11" Foreground="#808080" Margin="0,0,0,8"/>

        <PasswordBox x:Name="txtMasterPw" Grid.Row="2" Background="#1A1A1A" Foreground="#E0E0E0" 
                     BorderBrush="#333333" FontFamily="Consolas" FontSize="14" Padding="8,6"
                     KeyDown="TxtMasterPw_KeyDown"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="CANCEL" Click="BtnCancel_Click" Padding="16,6" Margin="0,0,8,0"
                    Background="#1A1A1A" Foreground="#808080" BorderBrush="#333333" 
                    FontFamily="Consolas" Cursor="Hand"/>
            <Button Content="UNLOCK" Click="BtnUnlock_Click" Padding="16,6"
                    Background="#1A1A1A" Foreground="#00FF41" BorderBrush="#00FF41" 
                    FontFamily="Consolas" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
