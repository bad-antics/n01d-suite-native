<Window x:Class="N01D.Vault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N01D :: VAULT" Height="700" Width="1050"
        Style="{StaticResource N01DWindow}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DAccentBrush}" BorderThickness="0,0,0,2">
            <Grid Margin="16,0">
                <TextBlock Text="[ N01D :: VAULT ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource N01DAccentBrush}" 
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnLock" Content="🔒 LOCK" Style="{StaticResource N01DButton}" 
                            Click="BtnLock_Click" Margin="0,0,8,0"/>
                    <Button x:Name="btnGenerate" Content="⚡ GENERATE" Style="{StaticResource N01DButton}" 
                            Click="BtnGenerate_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Entry List -->
            <Border Grid.Column="0" Background="{StaticResource N01DBackgroundAltBrush}" 
                    CornerRadius="5" BorderBrush="{StaticResource N01DBorderBrush}" 
                    BorderThickness="1" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ENTRIES" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="12" FontWeight="Bold" Foreground="{StaticResource N01DSecondaryBrush}" 
                               Margin="12,10,12,4"/>

                    <TextBox x:Name="txtSearch" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             Margin="8,4" TextChanged="TxtSearch_TextChanged">
                        <TextBox.Tag>Search entries...</TextBox.Tag>
                    </TextBox>

                    <ListBox x:Name="lstEntries" Grid.Row="2" Style="{StaticResource N01DListBox}" 
                             Margin="8,4" SelectionChanged="LstEntries_SelectionChanged"
                             DisplayMemberPath="Title"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8" HorizontalAlignment="Center">
                        <Button Content="+ ADD" Style="{StaticResource N01DButton}" 
                                Click="BtnAdd_Click" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="- DEL" Style="{StaticResource N01DButton}" 
                                Click="BtnDelete_Click" FontSize="11"
                                Foreground="{StaticResource N01DAccentBrush}" 
                                BorderBrush="{StaticResource N01DAccentBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: Entry Details -->
            <Border Grid.Column="1" Background="{StaticResource N01DBackgroundAltBrush}" 
                    CornerRadius="5" BorderBrush="{StaticResource N01DBorderBrush}" 
                    BorderThickness="1" Margin="4,0,0,0">
                <Grid x:Name="pnlDetails" Margin="16" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="TITLE" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,2"/>
                    <TextBox x:Name="txtTitle" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                             FontSize="16" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2" Text="USERNAME / EMAIL" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,2"/>
                    <Grid Grid.Row="3" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtUsername" Style="{StaticResource N01DTextBox}"/>
                        <Button Grid.Column="1" Content="📋" Style="{StaticResource N01DButton}" 
                                Click="BtnCopyUser_Click" Margin="4,0,0,0" Padding="8,4"
                                ToolTip="Copy username"/>
                    </Grid>

                    <TextBlock Grid.Row="4" Text="PASSWORD" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,2"/>
                    <Grid Grid.Row="5" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="txtPassword" Background="{StaticResource N01DBackgroundAltBrush}" 
                                     Foreground="{StaticResource N01DTextBrush}" 
                                     BorderBrush="{StaticResource N01DBorderBrush}" 
                                     FontFamily="{StaticResource N01DMonoFont}" 
                                     Padding="8,4" BorderThickness="1"/>
                        <Button Grid.Column="1" Content="👁" Style="{StaticResource N01DButton}" 
                                Click="BtnTogglePassword_Click" Margin="4,0,0,0" Padding="8,4"
                                ToolTip="Show/hide password"/>
                        <Button Grid.Column="2" Content="📋" Style="{StaticResource N01DButton}" 
                                Click="BtnCopyPass_Click" Margin="4,0,0,0" Padding="8,4"
                                ToolTip="Copy password (auto-clears in 15s)"/>
                    </Grid>

                    <TextBlock Grid.Row="6" Text="NOTES" FontFamily="{StaticResource N01DMonoFont}" 
                               FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" Margin="0,0,0,2"/>
                    <TextBox x:Name="txtNotes" Grid.Row="6" Style="{StaticResource N01DTextBox}" 
                             Margin="0,18,0,0" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"/>

                    <Button Grid.Row="7" Content="💾 SAVE" Style="{StaticResource N01DButton}" 
                            Click="BtnSave_Click" HorizontalAlignment="Right" Margin="0,12,0,0"
                            FontSize="13" Padding="20,8"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="lblStatus" Text="[ LOCKED ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DWarningBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="N01D Vault v1.0.0 | bad-antics" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
