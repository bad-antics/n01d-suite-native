<Window x:Class="N01D.Clip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N01D :: CLIP" Height="650" Width="700"
        Style="{StaticResource N01DWindow}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DWarningBrush}" BorderThickness="0,0,0,2">
            <Grid Margin="16,0">
                <TextBlock Text="[ N01D :: CLIP ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource N01DWarningBrush}" 
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnToggle" Content="⏸ PAUSE" Style="{StaticResource N01DButton}" 
                            Click="BtnToggle_Click" Margin="0,0,8,0"/>
                    <Button Content="🗑 CLEAR ALL" Style="{StaticResource N01DButton}" 
                            Click="BtnClearAll_Click"
                            Foreground="{StaticResource N01DAccentBrush}" 
                            BorderBrush="{StaticResource N01DAccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search -->
        <TextBox x:Name="txtSearch" Grid.Row="1" Style="{StaticResource N01DTextBox}" 
                 Margin="8,8,8,4" TextChanged="TxtSearch_TextChanged" Tag="Search clipboard history..."/>

        <!-- Clip List -->
        <ListBox x:Name="lstClips" Grid.Row="2" Style="{StaticResource N01DListBox}" 
                 Margin="8,4" SelectionChanged="LstClips_SelectionChanged"
                 MouseDoubleClick="LstClips_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CategoryIcon}" FontSize="16" 
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Preview}" Foreground="#E0E0E0" 
                                       FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding TimeAgo}" Foreground="#808080" 
                                       FontFamily="Consolas" FontSize="10"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding SizeLabel}" Foreground="#808080" 
                                   FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" Margin="8,0"/>
                        <TextBlock Grid.Column="3" Text="{Binding PinIcon}" FontSize="14" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Preview / Actions -->
        <Border Grid.Row="3" Background="{StaticResource N01DBackgroundAltBrush}" 
                Margin="8,4,8,8" Padding="8" CornerRadius="5" 
                BorderBrush="{StaticResource N01DBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtPreview" Grid.Column="0" Style="{StaticResource N01DTextBox}" 
                         IsReadOnly="True" MaxHeight="80" TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto"/>
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Button Content="📋 PASTE" Style="{StaticResource N01DButton}" 
                            Click="BtnPaste_Click" Margin="0,0,0,4" FontSize="11"/>
                    <Button Content="📌 PIN" Style="{StaticResource N01DButton}" 
                            Click="BtnPin_Click" Margin="0,0,0,4" FontSize="11"/>
                    <Button Content="🗑 DEL" Style="{StaticResource N01DButton}" 
                            Click="BtnDeleteOne_Click" FontSize="11"
                            Foreground="{StaticResource N01DAccentBrush}" 
                            BorderBrush="{StaticResource N01DAccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{StaticResource N01DBackgroundAltBrush}" 
                BorderBrush="{StaticResource N01DBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="lblStatus" Text="[ MONITORING ]" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DPrimaryBrush}" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="N01D Clip v1.0.0 | bad-antics" FontFamily="{StaticResource N01DMonoFont}" 
                           FontSize="11" Foreground="{StaticResource N01DTextDimBrush}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
